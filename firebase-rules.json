{
  "rules": {
    "requests": {
      ".read": true,
      "$requestId": {
        ".write": "!data.exists()",
        ".validate": "newData.hasChildren(['name', 'phone', 'nationality', 'country', 'city', 'maritalStatus', 'createdAt'])",
        "name": {
          ".validate": "newData.isString() && newData.val().length >= 3 && newData.val().length <= 100"
        },
        "phone": {
          ".validate": "newData.isString() && newData.val().length >= 7 && newData.val().length <= 25"
        },
        "nationality": {
          ".validate": "newData.isString() && newData.val().length <= 50"
        },
        "country": {
          ".validate": "newData.isString() && newData.val().length <= 50"
        },
        "city": {
          ".validate": "newData.isString() && newData.val().length <= 80"
        },
        "maritalStatus": {
          ".validate": "newData.val() === 'أعزب' || newData.val() === 'غير أعزب'"
        },
        "income": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "incomeCurrency": {
          ".validate": "newData.isString() && newData.val().length <= 80"
        },
        "createdAt": {
          ".validate": "newData.isNumber()"
        },
        "$other": {
          ".validate": false
        }
      }
    }
  }
}
